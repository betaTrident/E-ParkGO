{
  "mcpServers": {
    "token-optimizer": {
      "type": "stdio",
      "command": "npx.cmd",
      "args": [
        "-y",
        "token-optimizer-mcp"
      ],
    },
    "cloudflare-docs": {
      "type": "http",
      "url": "https://docs.mcp.cloudflare.com/mcp",
    },
    "firecrawl": {
      "type": "stdio",
      "command": "npx.cmd",
      "args": [
        "-y",
        "firecrawl-mcp"
      ],
      "env": {
        "FIRECRAWL_API_KEY": "YOUR_ACTUAL_FIRECRAWL_KEY"
      }
    },
    "github": {
      "type": "stdio",
      "command": "npx.cmd",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github@2025.4.8"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "YOUR_ACTUAL_GITHUB_PAT"
      }
    },
    "context7": {
      "type": "stdio",
      "command": "npx.cmd",
      "args": [
        "-y",
        "@upstash/context7-mcp@2.1.4"
      ]
    },
    "exa": {
      "type": "stdio",
      "command": "npx.cmd",
      "args": [
        "-y",
        "exa-mcp-server"
      ],
      "env": {
        "EXA_API_KEY": "YOUR_ACTUAL_EXA_KEY"
      }
    },
    "memory": {
      "type": "stdio",
      "command": "npx.cmd",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory@2026.1.26"
      ]
    },
    "playwright": {
      "type": "stdio",
      "command": "npx.cmd",
      "args": [
        "-y",
        "@playwright/mcp@0.0.69",
        "--extension"
      ]
    },
    "sequential-thinking": {
      "type": "stdio",
      "command": "npx.cmd",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking@2025.12.18"
      ]
    },
    "astro": {
      "type": "stdio",
      "command": "npx.cmd",
      "args": [
        "-y",
        "mcp-remote",
        "https://mcp.docs.astro.build/mcp"
      ]
    },
    "mapbox-mcp": {
      "type": "http",
      "url": "https://mcp.mapbox.com/mcp",
    },
    "supabase": {
      "type": "http",
      "url": "https://mcp.supabase.com/mcp",
    }
  }
}